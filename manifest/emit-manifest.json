  "claude_rules": [
    { "template": "templates/rules/frontend-core.mdc.template", "target": ".claude/rules/frontend-core.md", "emit_strategies": ["full", "portable-only"], "tools": ["Claude Code"] },
    { "template": "templates/rules/typescript-react.mdc.template", "target": ".claude/rules/typescript-react.md", "emit_strategies": ["full", "portable-only"], "tools": ["Claude Code"] },
    { "template": "templates/rules/ui-components.mdc.template", "target": ".claude/rules/ui-components.md", "emit_strategies": ["full", "portable-only"], "tools": ["Claude Code"] },
    { "template": "templates/rules/frontend-security.mdc.template", "target": ".claude/rules/frontend-security.md", "emit_strategies": ["full", "portable-only"], "tools": ["Claude Code"] },
    { "template": "templates/rules/shell-conventions.mdc.template", "target": ".claude/rules/shell-conventions.md", "emit_strategies": ["full", "portable-only"], "tools": ["Claude Code"] }
