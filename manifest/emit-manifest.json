    "portable-only": {
      "required_paths": [
        "AGENTS.md",
        "HARNESS_CHANGELOG.md",
        "agents/ORCHESTRATION.md",
        ".agents/skills/frontend-verify/SKILL.md",
        ".agents/skills/frontend-security/SKILL.md",
        ".agent-scripts/validate-target-harness.sh",
        ".agent-scripts/validate-target-harness.ps1",
        ".agent-scripts/sync-skills.sh",
        ".agent-scripts/sync-skills.ps1",
        ".agent-scripts/lib/secret-patterns.sh",
        ".agent-scripts/lib/secret-patterns.ps1",
        ".agent-scripts/lib/normalize-target-path.sh",
        ".agent-scripts/lib/normalize-target-path.ps1"
      ]
    },
    "cursor-only": {
      "required_paths": [
        "AGENTS.md",
        "HARNESS_CHANGELOG.md",
        ".cursor/ORCHESTRATION.md",
        ".cursor/rules/frontend-core.mdc",
        ".cursor/rules/frontend-security.mdc",
        ".cursor/rules/shell-conventions.mdc",
        ".cursor/hooks.json",
        ".cursor/skills/frontend-verify/SKILL.md",
        ".cursor/skills/frontend-security/SKILL.md",
        ".agent-scripts/validate-target-harness.sh",
        ".agent-scripts/validate-target-harness.ps1",
        ".agent-scripts/sync-skills.sh",
        ".agent-scripts/sync-skills.ps1",
        ".agent-scripts/lib/secret-patterns.sh",
        ".agent-scripts/lib/secret-patterns.ps1",
        ".agent-scripts/lib/normalize-target-path.sh",
        ".agent-scripts/lib/normalize-target-path.ps1"
      ]
    }
  },
  "conditional_paths": [
    { "path": ".cursor/hooks/scan-secrets.sh", "profiles": ["full", "cursor-only"], "feature": "secret_scan_hook" },
    { "path": ".cursor/hooks/scan-secrets.ps1", "profiles": ["full", "cursor-only"], "feature": "secret_scan_hook" },
    { "path": ".cursor/hooks/deny-dangerous.sh", "profiles": ["full", "cursor-only"], "feature": "shell_guard" },
    { "path": ".cursor/hooks/deny-dangerous.ps1", "profiles": ["full", "cursor-only"], "feature": "shell_guard" },
    { "path": ".codex/config.toml", "profiles": ["full", "portable-only"], "feature": "codex_hooks" },
    { "path": ".github/workflows/harness-validate.yml", "profiles": ["full", "portable-only", "cursor-only"], "feature": "harness_ci_workflow" },
    { "path": ".github/workflows/secret-scan.yml", "profiles": ["full", "portable-only", "cursor-only"], "feature": "gitleaks_ci" },
    { "path": ".agents/harness/allowed-domains.txt", "profiles": ["full", "portable-only"], "feature": "agent_security_hardening" },
    { "path": ".agents/harness/mcp-allowlist.json", "profiles": ["full", "portable-only"], "feature": "agent_security_hardening" },
