        { "template": "templates/hooks/scan-secrets.sh", "target": ".cursor/hooks/scan-secrets.sh", "feature": "secret_scan_hook" },
        { "template": "templates/hooks/scan-secrets.ps1", "target": ".cursor/hooks/scan-secrets.ps1", "feature": "secret_scan_hook" }
