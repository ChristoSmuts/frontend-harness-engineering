        { "template": "templates/hooks/verify-frontend.ps1", "target": ".cursor/hooks/verify-frontend.ps1" },
        { "template": "templates/hooks/deny-dangerous.sh", "target": ".cursor/hooks/deny-dangerous.sh" },
        { "template": "templates/hooks/deny-dangerous.ps1", "target": ".cursor/hooks/deny-dangerous.ps1", "feature": "shell_guard" },
        { "template": "templates/hooks/scan-secrets.sh", "target": ".cursor/hooks/scan-secrets.sh", "feature": "secret_scan_hook" },
        { "template": "templates/hooks/scan-secrets.ps1", "target": ".cursor/hooks/scan-secrets.ps1", "feature": "secret_scan_hook" }
      ]
    }
  },
  "skills": [
    { "name": "frontend-verify", "template": "templates/skills/frontend-verify/SKILL.md", "priority": "P1", "always": true },
