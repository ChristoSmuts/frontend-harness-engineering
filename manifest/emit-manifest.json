    { "path": ".cursor/hooks/deny-unapproved-mcp.ps1", "profiles": ["full", "cursor-only"], "feature": "agent_security_hardening" }
  ],
  "maintenance_scripts": [
    { "template": "scripts/validate-target-harness.sh", "target": ".agent-scripts/validate-target-harness.sh", "substitute": false },
    { "template": "scripts/validate-target-harness.ps1", "target": ".agent-scripts/validate-target-harness.ps1", "substitute": false },
    { "template": "scripts/sync-skills.sh", "target": ".agent-scripts/sync-skills.sh", "substitute": false },
    { "template": "scripts/sync-skills.ps1", "target": ".agent-scripts/sync-skills.ps1", "substitute": false },
    { "template": "scripts/register-harness-growth.sh", "target": ".agent-scripts/register-harness-growth.sh", "substitute": false },
    { "template": "scripts/register-harness-growth.ps1", "target": ".agent-scripts/register-harness-growth.ps1", "substitute": false },
    { "template": "scripts/lib/secret-patterns.sh", "target": ".agent-scripts/lib/secret-patterns.sh", "substitute": false },
    { "template": "scripts/lib/secret-patterns.ps1", "target": ".agent-scripts/lib/secret-patterns.ps1", "substitute": false },
    { "template": "scripts/lib/normalize-target-path.sh", "target": ".agent-scripts/lib/normalize-target-path.sh", "substitute": false },
    { "template": "scripts/lib/normalize-target-path.ps1", "target": ".agent-scripts/lib/normalize-target-path.ps1", "substitute": false },
    { "template": "scripts/lib/harness-integrity.sh", "target": ".agent-scripts/lib/harness-integrity.sh", "substitute": false },
    { "template": "scripts/lib/harness-integrity.ps1", "target": ".agent-scripts/lib/harness-integrity.ps1", "substitute": false },
    { "template": "scripts/lib/shell-guard.sh", "target": ".agent-scripts/lib/shell-guard.sh", "substitute": false },
    { "template": "scripts/lib/shell-guard.ps1", "target": ".agent-scripts/lib/shell-guard.ps1", "substitute": false }
  ],
  "artifacts": [
    { "id": "agents-md", "template": "templates/AGENTS.md.template", "target": "AGENTS.md", "emit_strategies": ["full", "portable-only", "cursor-only"], "substitute": true },
    { "id": "harness-changelog", "template": "templates/HARNESS_CHANGELOG.md.template", "target": "HARNESS_CHANGELOG.md", "emit_strategies": ["full", "portable-only", "cursor-only"], "substitute": true },
    { "id": "orchestration-shared", "template": "templates/ORCHESTRATION.shared.md.template", "target": "agents/ORCHESTRATION.md", "emit_strategies": ["full", "portable-only"], "substitute": true },
    { "id": "orchestration-cursor-hooks", "template": "templates/ORCHESTRATION.cursor-hooks.md.template", "target": ".cursor/ORCHESTRATION.cursor-hooks.md", "emit_strategies": ["full", "cursor-only"], "tools": ["Cursor"], "substitute": true },
    { "id": "claude-md", "template": "templates/CLAUDE.md.template", "target": "CLAUDE.md", "emit_strategies": ["full", "portable-only"], "tools": ["Claude Code"], "substitute": true },
    { "id": "gemini-md", "template": "templates/GEMINI.md.template", "target": "GEMINI.md", "emit_strategies": ["full", "portable-only"], "tools": ["Gemini CLI"], "substitute": true },
    { "id": "codex-config", "template": "templates/codex/config.toml.template", "target": ".codex/config.toml", "emit_strategies": ["full", "portable-only"], "tools": ["Codex CLI"], "feature": "codex_hooks", "substitute": true },
    { "id": "harness-ci-workflow", "template": "templates/github/workflows/harness-validate.yml.template", "target": ".github/workflows/harness-validate.yml", "emit_strategies": ["full", "portable-only", "cursor-only"], "feature": "harness_ci_workflow", "substitute": true },
    { "id": "gitleaks-ci-workflow", "template": "templates/github/workflows/secret-scan.yml.template", "target": ".github/workflows/secret-scan.yml", "emit_strategies": ["full", "portable-only", "cursor-only"], "feature": "gitleaks_ci", "substitute": true }
  ],
  "cursor_rules": [
    { "template": "templates/rules/frontend-core.mdc.template", "target": ".cursor/rules/frontend-core.mdc", "emit_strategies": ["full", "cursor-only"], "tools": ["Cursor"] },
    { "template": "templates/rules/typescript-react.mdc.template", "target": ".cursor/rules/typescript-react.mdc", "emit_strategies": ["full", "cursor-only"], "tools": ["Cursor"] },
    { "template": "templates/rules/ui-components.mdc.template", "target": ".cursor/rules/ui-components.mdc", "emit_strategies": ["full", "cursor-only"], "tools": ["Cursor"] },
    { "template": "templates/rules/frontend-security.mdc.template", "target": ".cursor/rules/frontend-security.mdc", "emit_strategies": ["full", "cursor-only"], "tools": ["Cursor"] },
    { "template": "templates/rules/shell-conventions.mdc.template", "target": ".cursor/rules/shell-conventions.mdc", "emit_strategies": ["full", "cursor-only"], "tools": ["Cursor"] }
