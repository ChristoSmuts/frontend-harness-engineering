  "hooks": {
    "unix": {
      "template": "templates/hooks/hooks.json.template",
      "target": ".cursor/hooks.json",
      "scripts": [
        { "template": "templates/hooks/verify-frontend.sh", "target": ".cursor/hooks/verify-frontend.sh" },
        { "template": "templates/hooks/verify-frontend.ps1", "target": ".cursor/hooks/verify-frontend.ps1" },
