{
  "emit_strategy": "full",
  "primary_tool": "Cursor",
  "harness_owner": "solo",
  "canonical_skills_dir": ".agents/skills/",
  "tools_in_use": ["Cursor", "Codex CLI"],
  "framework": "Next.js 15 App Router",
  "package_manager": "pnpm",
  "platform_primary": "unix",
  "toolkit_path": ".",
  "target_path": ".",
  "project_name": "Fixture App",
  "repo_type": "greenfield",
  "monorepo": false,
  "lint_cmd": "pnpm biome check --write .",
  "typecheck_cmd": "pnpm exec tsc --noEmit",
  "install_cmd": "pnpm install",
  "unit_test_single_cmd": "pnpm vitest run path/to/file.test.tsx",
  "routes_path": "src/app",
  "components_path": "src/components",
  "shared_ui_path": "src/components/ui",
  "api_client_path": "src/lib/api",
  "forbidden_paths": "`.next`, `dist`, `node_modules`",
  "styling": "Tailwind",
  "ui_library": "shadcn/ui",
  "scope_globs": "src/**",
  "mcp_policy": "Prefer CLI for git/GitHub. Enable design MCP only for design-to-code tasks.",
  "public_env_prefix": "NEXT_PUBLIC_",
  "auth_stack": "none (follow existing patterns)",
  "skills_dir": ".agents/skills/",
  "toolkit_sha": "golden",
  "bootstrap_date": "2026-06-04",
  "features": {
    "shadcn": true,
    "playwright": false,
    "data_fetching": false,
    "forms_validation": false,
    "accessibility": false,
    "shell_guard": true,
    "secret_scan_hook": true,
    "codex_hooks": true,
    "harness_ci_workflow": true
  }
}
