#!/usr/bin/env bash
# Optional pre-commit hook: sync skill mirrors when canonical skills change.
# Install: cp templates/hooks/pre-commit-sync.example .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

if git diff --cached --name-only | grep -q '^\.agents/skills/'; then
  if [[ -d .cursor/skills || -d .claude/skills ]]; then
    bash scripts/sync-skills.sh --all-mirrors
    git add .cursor/skills .claude/skills 2>/dev/null || true
    git add .claude/skills 2>/dev/null || true
  fi
fi

exit 0
