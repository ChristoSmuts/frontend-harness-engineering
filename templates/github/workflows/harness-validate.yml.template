# Harness validation — copy to .github/workflows/harness-validate.yml
# Validates agent harness files on PRs that touch harness paths.

name: Harness validate

on:
  push:
    branches: [main, master]
    paths:
      - "AGENTS.md"
      - "HARNESS_CHANGELOG.md"
      - "agents/**"
      - ".agents/**"
      - ".cursor/**"
      - ".claude/**"
      - "{{HARNESS_SCRIPTS_DIR}}/**"
  pull_request:
    paths:
      - "AGENTS.md"
      - "HARNESS_CHANGELOG.md"
      - "agents/**"
      - ".agents/**"
      - ".cursor/**"
      - ".claude/**"
      - "{{HARNESS_SCRIPTS_DIR}}/**"

jobs:
  validate-unix:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - name: Validate harness (strict)
        run: bash {{HARNESS_SCRIPTS_DIR}}/validate-target-harness.sh --strict .

  sync-check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - name: Sync mirrors and fail on drift
        run: |
          if [[ ! -d .agents/skills ]]; then
            echo "No canonical skills dir; skip sync-check"
            exit 0
          fi
          if [[ ! -d .cursor/skills && ! -d .claude/skills ]]; then
            echo "No mirrors; skip sync-check"
            exit 0
          fi
          find .cursor/skills .claude/skills -name SKILL.md -exec sed -i 's/\r$//' {} +
          bash {{HARNESS_SCRIPTS_DIR}}/sync-skills.sh --all-mirrors
          git diff --exit-code -- .cursor/skills .claude/skills || {
            echo "Mirror drift: run sync-skills locally and commit"
            exit 1
          }
