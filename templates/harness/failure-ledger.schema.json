{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/frontend-harness-engineering/harness/failure-ledger.schema.json",
  "title": "HarnessFailureLedger",
  "type": "object",
  "required": ["version", "entries"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "summary",
          "trigger",
          "count",
          "first_seen",
          "last_seen",
          "fix_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 8,
            "description": "Stable fingerprint (e.g. sha256 of normalized summary + category)"
          },
          "category": {
            "type": "string",
            "enum": [
              "ui-components",
              "verify",
              "security",
              "routing",
              "data-fetching",
              "orchestration",
              "other"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "trigger": {
            "type": "string",
            "enum": ["user_correction", "verify_failure", "explicit"]
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "first_seen": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen": {
            "type": "string",
            "format": "date-time"
          },
          "fix_status": {
            "type": "string",
            "enum": ["open", "applied", "wontfix"]
          },
          "fix_artifact": {
            "type": "string",
            "description": "e.g. skill:shadcn-components, rule:ui-components, hook:verify, orchestration"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
