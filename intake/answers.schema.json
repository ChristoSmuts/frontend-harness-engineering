{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/frontend-harness-engineering/intake/answers.schema.json",
  "title": "FrontendHarnessIntake",
  "type": "object",
  "required": [
    "emit_strategy",
    "primary_tool",
    "harness_owner",
    "canonical_skills_dir",
    "tools_in_use",
    "framework",
    "package_manager",
    "platform_primary",
    "toolkit_path",
    "project_name",
    "lint_cmd",
    "typecheck_cmd",
    "install_cmd",
    "routes_path",
    "components_path",
    "shared_ui_path",
    "api_client_path",
    "forbidden_paths",
    "styling",
    "ui_library"
  ],
  "properties": {
    "emit_strategy": {
      "type": "string",
      "enum": ["full", "portable-only", "cursor-only"]
    },
    "primary_tool": {
      "type": "string",
      "description": "Cursor, Claude Code, Codex CLI, Gemini CLI, etc."
    },
    "harness_owner": {
      "type": "string",
      "description": "@handle or solo"
    },
    "canonical_skills_dir": {
      "type": "string",
      "default": ".agents/skills/"
    },
    "tools_in_use": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "framework": {
      "type": "string",
      "description": "Next.js App Router, Vite+React, Remix, Nuxt, SvelteKit, Astro, Vue+Vite, Angular, React Native, Expo, other"
    },
    "package_manager": {
      "type": "string",
      "enum": ["pnpm", "npm", "yarn", "bun"]
    },
    "platform_primary": {
      "type": "string",
      "enum": ["unix", "windows"],
      "default": "unix"
    },
    "toolkit_path": {
      "type": "string",
      "description": "Path to toolkit root (contains templates/)"
    },
    "project_name": { "type": "string" },
    "repo_type": {
      "type": "string",
      "enum": ["greenfield", "brownfield"],
      "default": "greenfield"
    },
    "monorepo": { "type": "boolean", "default": false },
    "app_package_path": { "type": "string" },
    "app_package_name": { "type": "string" },
    "lint_cmd": { "type": "string" },
    "typecheck_cmd": { "type": "string" },
    "install_cmd": { "type": "string" },
    "unit_test_single_cmd": { "type": "string" },
    "routes_path": { "type": "string" },
    "components_path": { "type": "string" },
    "shared_ui_path": { "type": "string" },
    "api_client_path": { "type": "string" },
    "forbidden_paths": { "type": "string" },
    "styling": { "type": "string" },
    "ui_library": { "type": "string" },
    "scope_globs": { "type": "string", "default": "src/**" },
    "mcp_policy": { "type": "string" },
    "skills_dir": { "type": "string" },
    "toolkit_sha": { "type": "string" },
    "bootstrap_date": { "type": "string" },
    "features": {
      "type": "object",
      "properties": {
        "shadcn": { "type": "boolean", "default": false },
        "playwright": { "type": "boolean", "default": false },
        "data_fetching": { "type": "boolean", "default": false },
        "forms_validation": { "type": "boolean", "default": false },
        "accessibility": { "type": "boolean", "default": false },
        "shell_guard": { "type": "boolean", "default": true },
        "codex_hooks": { "type": "boolean", "default": false },
        "harness_ci_workflow": { "type": "boolean", "default": true }
      },
      "additionalProperties": true
    },
    "merge_policy": {
      "type": "object",
      "additionalProperties": { "type": "string", "enum": ["create", "merge", "skip"] }
    }
  },
  "allOf": [
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "tools_in_use": {
                "contains": { "type": "string", "pattern": "(?i)cursor" }
              }
            }
          },
          {
            "properties": {
              "tools_in_use": {
                "contains": { "type": "string", "pattern": "(?i)codex|gemini" }
              }
            }
          }
        ]
      },
      "then": {
        "properties": {
          "emit_strategy": { "const": "full" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "tools_in_use": {
            "not": {
              "contains": { "type": "string", "pattern": "(?i)cursor" }
            }
          }
        },
        "required": ["tools_in_use"]
      },
      "then": {
        "properties": {
          "emit_strategy": { "not": { "const": "cursor-only" } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "emit_strategy": { "const": "cursor-only" }
        }
      },
      "then": {
        "properties": {
          "canonical_skills_dir": {
            "pattern": "^\\.cursor/skills"
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
